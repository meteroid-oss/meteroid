      "type": "string",
      "enum": [
        "MONTHLY",
        "QUARTERLY",
        "ANNUAL"
      ],
      "default": "MONTHLY"
    },
    "v1CancelSubscriptionResponse": {
      "type": "object",
      "properties": {
        "subscription": {
          "$ref": "#/definitions/v1Subscription"
        }
      },
      "description": "Cancel subscription response",
      "title": "CancelSubscriptionResponse",
      "required": [
        "subscription"
      ]
    },
    "v1CreateSubscriptionRequest": {
      "type": "object",
