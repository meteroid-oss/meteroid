    "v1Pagination": {
      "type": "object",
      "properties": {
        "limit": {
          "type": "integer",
          "format": "int64"
        },
        "offset": {
          "type": "integer",
          "format": "int64"
        }
      }
    },
    "v1PaginationResponse": {
      "type": "object",
      "properties": {
        "limit": {
          "type": "integer",
          "format": "int64"
        },
        "offset": {
          "type": "integer",
          "format": "int64"
        },
        "total": {
          "type": "integer",
          "format": "int64"
        }
      }
    },
    "v1Subscription": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "tenantId": {
          "type": "string"
        },
        "customerId": {
          "type": "string"
        },
        "planVersionId": {
          "type": "string"
        },
        "version": {
          "type": "integer",
          "format": "int64"
        },
        "billingStartDate": {
          "$ref": "#/definitions/v1Date"
        },
        "billingEndDate": {
          "$ref": "#/definitions/v1Date"
        },
        "netTerms": {
          "type": "integer",
          "format": "int32"
        },
        "currency": {
          "type": "string"
        },
        "customerName": {
          "type": "string"
        },
        "planId": {
          "type": "string"
        },
        "planName": {
          "type": "string"
        },
        "parameters": {
          "$ref": "#/definitions/v1SubscriptionParameters"
        },
        "status": {
          "$ref": "#/definitions/v1SubscriptionStatus"
        },
        "canceledAt": {
          "type": "string",
          "format": "date-time"
        }
