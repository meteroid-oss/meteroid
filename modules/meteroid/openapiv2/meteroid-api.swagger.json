          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SubscriptionsServiceApplySlotsDeltaBody"
            }
          }
        ],
        "tags": [
          "subscription"
        ]
      }
