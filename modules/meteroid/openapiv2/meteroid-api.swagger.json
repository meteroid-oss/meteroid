      "type": "object",
      "properties": {
        "subscriptions": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1Subscription"
          }
        },
        "paginationMeta": {
          "$ref": "#/definitions/v1PaginationResponse"
        }
      },
      "description": "List subscriptions response",
      "title": "ListSubscriptionsResponse",
      "required": [
        "subscriptions",
        "paginationMeta"
      ]
