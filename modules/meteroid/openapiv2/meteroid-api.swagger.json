      },
      "description": "Apply slots delta request",
      "title": "ApplySlotsDeltaRequest",
      "required": [
        "priceComponentId",
        "delta"
      ]
    },
    "SubscriptionsServiceCancelSubscriptionBody": {
      "type": "object",
      "properties": {
        "reason": {
          "type": "string"
        },
        "effectiveAt": {
          "$ref": "#/definitions/CancelSubscriptionRequestEffectiveAt"
        }
      },
      "description": "Cancel subscription request",
      "title": "CancelSubscriptionRequest",
      "required": [
        "effectiveAt"
      ]
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1ApplySlotsDeltaResponse": {
      "type": "object",
      "properties": {
        "activeSlots": {
          "type": "integer",
          "format": "int64"
        }
      },
      "description": "Apply slots delta response",
      "title": "ApplySlotsDeltaResponse",
      "required": [
        "activeSlots"
      ]
    },
