          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SubscriptionsServiceCancelSubscriptionBody"
            }
          }
        ],
        "tags": [
          "subscription"
        ]
      }
